{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "velite build --clean && next build",
    "dev": "next dev --turbopack",
    "dev:email": "email dev --dir src/features/emails/templates --port 4000",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --fix --max-warnings=0",
    "lint:check": "eslint . --max-warnings=0",
    "prepare": "husky",
    "security:audit": "pnpm audit --audit-level=moderate",
    "start": "next start",
    "static-analysis": "prettier --check . && pnpm run lint:check && pnpm run type-check",
    "type-check": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next-safe-action/adapter-react-hook-form": "^2.0.6",
    "@next/mdx": "^16.2.9",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-email/components": "^1.0.12",
    "@shikijs/rehype": "^4.3.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@types/mdx": "^2.0.14",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "next-safe-action": "^8.5.5",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "resend": "^6.16.0",
    "sharp": "^0.35.2",
    "shiki": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-email": "6.6.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "velite": "^0.4.0"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "pnpm": ">=11.6.0"
  }
}
